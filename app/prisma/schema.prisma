generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  ORG_FINANCE
  ORG_SUPPORT
  CLIENT_PORTAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CLIENT
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BoletoStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum InvoiceType {
  NFE
  NFSE
}

enum InvoiceStatus {
  PENDING
  ISSUED
  CANCELLED
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum SendStatus {
  PENDING
  SENT
  FAILED
  NO_EMAIL
  NO_CADASTRO
  SIMULATED
}

enum ProductType {
  PRODUCT
  SERVICE
}

enum ProposalItemType {
  MONTHLY_SERVICE
  ONETIME_SERVICE
  EQUIPMENT_RENTAL
  EQUIPMENT_PURCHASE
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ContractStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  EXPIRED
  CANCELLED
}

enum PixStatus {
  PENDING
  PAID
  EXPIRED
  CANCELLED
}

enum AccessLevel {
  NONE
  READ
  EDIT
  CREATE
  FULL
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  OVERDUE
  SUSPENDED
  CANCELLED
}

enum NotificationType {
  TICKET_NEW
  TICKET_REPLY
  TICKET_STATUS_CHANGE
  TICKET_ASSIGNED
  BOLETO_DUE
  BOLETO_OVERDUE
  BOLETO_PAID
  INVOICE_ISSUED
  CAMPAIGN_COMPLETED
  PORTAL_INVITE
}

model Organization {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  cnpj        String?
  logo_url    String?
  plan                 String             @default("free")
  is_active            Boolean            @default(true)
  subscription_status  SubscriptionStatus @default(TRIAL)
  trial_ends_at        DateTime?
  subscription_ends_at DateTime?
  billing_email        String?
  notes                String?

  smtp_host     String?
  smtp_port     Int?    @default(465)
  smtp_user     String?
  smtp_pass_enc String?
  smtp_from     String?
  smtp_use_tls  Boolean @default(true)
  smtp_verified Boolean @default(false)

  send_interval_sec Int      @default(15)
  cnpjs_ignore      String[] @default([])

  sla_low              Int @default(72)
  sla_medium           Int @default(24)
  sla_high             Int @default(8)
  sla_critical         Int @default(2)
  sla_auto_close_hours Int @default(72)

  webhook_url    String?
  webhook_secret String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  memberships    Membership[]
  clients        Client[]
  campaigns      Campaign[]
  boletos        Boleto[]
  invoices       Invoice[]
  tickets        Ticket[]
  notifications  Notification[]
  activity_log   ActivityLog[]
  email_templates EmailTemplate[]
  webhook_events WebhookEvent[]
  products       Product[]
  proposals      Proposal[]
  contracts      Contract[]
  pix_charges          PixCharge[]
  client_tech_sheets   ClientTechSheet[]
  sales_labels         SalesLabel[]
  knowledge_articles   KnowledgeArticle[]
  empresas             Empresa[]
  carteiras            Carteira[]
  categorias_financeiras CategoriaFinanceira[]
  centros_custo        CentroCusto[]
  contas_pagar         ContaPagar[]
  contas_receber       ContaReceber[]

  @@map("organizations")
}

model Empresa {
  id              String   @id @default(cuid())
  organization_id String
  name            String
  cnpj            String
  email           String?
  phone           String?
  address         String?
  logo_url        String?
  is_active       Boolean  @default(true)

  asaas_api_key      String?
  asaas_environment  String  @default("SANDBOX")

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization   Organization  @relation(fields: [organization_id], references: [id])
  clients        Client[]
  boletos        Boleto[]
  invoices       Invoice[]
  pix_charges    PixCharge[]
  carteiras      Carteira[]
  contas_pagar   ContaPagar[]
  contas_receber ContaReceber[]

  @@unique([organization_id, cnpj])
  @@index([organization_id])
  @@map("empresas")
}

model Carteira {
  id              String   @id @default(cuid())
  organization_id String
  empresa_id      String
  name            String
  description     String?
  type            String   @default("CORRENTE")
  bank            String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization   Organization   @relation(fields: [organization_id], references: [id])
  empresa        Empresa        @relation(fields: [empresa_id], references: [id])
  contas_pagar   ContaPagar[]
  contas_receber ContaReceber[]

  @@index([organization_id])
  @@index([empresa_id])
  @@map("carteiras")
}

model CategoriaFinanceira {
  id              String   @id @default(cuid())
  organization_id String
  name            String
  type            String   @default("AMBOS")
  color           String   @default("#6366f1")
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization   Organization   @relation(fields: [organization_id], references: [id])
  contas_pagar   ContaPagar[]
  contas_receber ContaReceber[]

  @@unique([organization_id, name])
  @@index([organization_id])
  @@map("categorias_financeiras")
}

model CentroCusto {
  id              String   @id @default(cuid())
  organization_id String
  name            String
  description     String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization   Organization   @relation(fields: [organization_id], references: [id])
  contas_pagar   ContaPagar[]
  contas_receber ContaReceber[]

  @@unique([organization_id, name])
  @@index([organization_id])
  @@map("centros_custo")
}

model ContaPagar {
  id              String   @id @default(cuid())
  organization_id String
  empresa_id      String
  carteira_id     String
  categoria_id    String?
  centro_custo_id String?

  title           String
  description     String?  @db.Text
  amount          Decimal  @db.Decimal(12, 2)
  due_date        DateTime
  paid_at         DateTime?
  paid_amount     Decimal? @db.Decimal(12, 2)

  supplier_name   String?
  supplier_doc    String?

  payment_method  String?
  document_number String?
  receipt_key     String?

  recurrence      String?
  recurrence_end  DateTime?
  parent_id       String?

  status          String   @default("PENDING")
  notes           String?  @db.Text

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization         @relation(fields: [organization_id], references: [id])
  empresa      Empresa              @relation(fields: [empresa_id], references: [id])
  carteira     Carteira             @relation(fields: [carteira_id], references: [id])
  categoria    CategoriaFinanceira? @relation(fields: [categoria_id], references: [id])
  centro_custo CentroCusto?         @relation(fields: [centro_custo_id], references: [id])

  @@index([organization_id])
  @@index([organization_id, empresa_id])
  @@index([organization_id, status])
  @@index([organization_id, due_date])
  @@map("contas_pagar")
}

model ContaReceber {
  id              String   @id @default(cuid())
  organization_id String
  empresa_id      String
  carteira_id     String
  client_id       String?
  boleto_id       String?  @unique
  pix_charge_id   String?  @unique
  categoria_id    String?
  centro_custo_id String?

  title           String
  description     String?  @db.Text
  amount          Decimal  @db.Decimal(12, 2)
  due_date        DateTime
  received_at     DateTime?
  received_amount Decimal? @db.Decimal(12, 2)

  payer_name      String?
  payer_doc       String?

  payment_method  String?
  document_number String?
  receipt_key     String?

  status          String   @default("PENDING")
  notes           String?  @db.Text

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization         @relation(fields: [organization_id], references: [id])
  empresa      Empresa              @relation(fields: [empresa_id], references: [id])
  carteira     Carteira             @relation(fields: [carteira_id], references: [id])
  client       Client?              @relation(fields: [client_id], references: [id])
  boleto       Boleto?              @relation(fields: [boleto_id], references: [id])
  pix_charge   PixCharge?           @relation(fields: [pix_charge_id], references: [id])
  categoria    CategoriaFinanceira? @relation(fields: [categoria_id], references: [id])
  centro_custo CentroCusto?         @relation(fields: [centro_custo_id], references: [id])

  @@index([organization_id])
  @@index([organization_id, empresa_id])
  @@index([organization_id, status])
  @@index([organization_id, due_date])
  @@map("contas_receber")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password_hash  String
  name           String
  avatar_url     String?
  role           UserRole @default(ORG_ADMIN)
  email_verified Boolean  @default(false)
  is_active      Boolean  @default(true)
  last_login_at  DateTime?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  memberships      Membership[]
  client_contacts  ClientContact[]
  assigned_tickets Ticket[]        @relation("AssignedTickets")
  notifications    Notification[]
  activity_log     ActivityLog[]

  @@map("users")
}

model Membership {
  id              String   @id @default(cuid())
  user_id         String
  organization_id String
  role            UserRole
  is_active       Boolean  @default(true)
  invited_by      String?
  invited_at      DateTime?
  accepted_at     DateTime?
  created_at      DateTime @default(now())

  user         User               @relation(fields: [user_id], references: [id])
  organization Organization       @relation(fields: [organization_id], references: [id])
  permissions  MemberPermission[]

  @@unique([user_id, organization_id])
  @@index([organization_id])
  @@map("memberships")
}

model MemberPermission {
  id            String      @id @default(cuid())
  membership_id String
  module        String
  access        AccessLevel @default(READ)
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  membership Membership @relation(fields: [membership_id], references: [id], onDelete: Cascade)

  @@unique([membership_id, module])
  @@map("member_permissions")
}

model Client {
  id              String   @id @default(cuid())
  organization_id String
  cnpj            String
  name            String
  trade_name      String?
  email              String?
  email_nfe          String?
  email_boleto       String?
  phone              String?
  address            String?   // legacy single-line, kept for compat
  address_street     String?
  address_number     String?
  address_complement String?
  address_district   String?
  address_city       String?
  address_state      String?
  address_zip        String?
  notes              String?
  empresa_id          String?
  is_active           Boolean   @default(true)
  portal_token        String?   @unique @default(cuid())
  last_portal_access  DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  organization   Organization   @relation(fields: [organization_id], references: [id])
  empresa        Empresa?       @relation(fields: [empresa_id], references: [id])
  contacts       ClientContact[]
  boletos        Boleto[]
  invoices       Invoice[]
  tickets        Ticket[]
  proposals      Proposal[]
  contracts      Contract[]
  pix_charges    PixCharge[]
  tech_sheet     ClientTechSheet?
  contas_receber ContaReceber[]

  @@unique([organization_id, cnpj])
  @@index([organization_id])
  @@map("clients")
}

model ClientTechSheet {
  id              String   @id @default(cuid())
  organization_id String
  client_id       String   @unique

  // Acesso Remoto
  remote_tool     String?
  remote_id       String?
  remote_password String?
  remote_notes    String?  @db.Text

  // Rede
  gateway         String?
  dns_primary     String?
  dhcp_range      String?
  network_notes   String?  @db.Text

  // Software / Servidores
  software_notes  String?  @db.Text

  // Contato principal
  contact_name    String?
  contact_role    String?
  contact_phone   String?
  contact_email   String?

  // Status
  status          String   @default("ACTIVE")

  // Anotações gerais
  notes           String?  @db.Text

  // Informações adicionais e histórico
  additional_info  String?  @db.Text
  updated_by_name  String?
  updated_by_id    String?

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id])
  client       Client       @relation(fields: [client_id], references: [id])

  @@index([organization_id])
  @@map("client_tech_sheets")
}

model ClientContact {
  id             String    @id @default(cuid())
  client_id      String
  user_id        String
  is_primary     Boolean   @default(false)
  invite_token   String?   @unique
  invite_expires DateTime?
  created_at     DateTime  @default(now())

  client Client @relation(fields: [client_id], references: [id])
  user   User   @relation(fields: [user_id], references: [id])

  @@unique([client_id, user_id])
  @@index([client_id])
  @@map("client_contacts")
}

model Boleto {
  id               String      @id @default(cuid())
  organization_id  String
  client_id        String
  number           String?
  description      String?
  amount           Decimal     @db.Decimal(12, 2)
  due_date         DateTime
  status           BoletoStatus @default(PENDING)
  paid_at          DateTime?
  paid_amount      Decimal?    @db.Decimal(12, 2)
  barcode          String?
  pdf_key          String?
  pdf_size_kb      Float?
  campaign_send_id  String?     @unique
  empresa_id        String?
  asaas_id          String?     @unique
  asaas_customer_id String?
  asaas_barcode     String?
  asaas_digitavel   String?
  asaas_url         String?
  notes             String?
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  organization   Organization   @relation(fields: [organization_id], references: [id])
  client         Client         @relation(fields: [client_id], references: [id])
  empresa        Empresa?       @relation(fields: [empresa_id], references: [id])
  campaign_send  CampaignSend?  @relation(fields: [campaign_send_id], references: [id])
  conta_receber  ContaReceber?

  @@index([organization_id])
  @@index([organization_id, client_id])
  @@index([organization_id, status])
  @@index([organization_id, due_date])
  @@map("boletos")
}

model Invoice {
  id               String        @id @default(cuid())
  organization_id  String
  client_id        String
  type             InvoiceType   @default(NFSE)
  status           InvoiceStatus @default(ISSUED)
  number           String?
  series           String?
  issue_date       DateTime
  amount           Decimal       @db.Decimal(12, 2)
  description      String?
  pdf_key          String?
  xml_key          String?
  pdf_size_kb      Float?
  campaign_send_id String?       @unique
  empresa_id       String?
  notes            String?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  organization  Organization  @relation(fields: [organization_id], references: [id])
  client        Client        @relation(fields: [client_id], references: [id])
  empresa       Empresa?      @relation(fields: [empresa_id], references: [id])
  campaign_send CampaignSend? @relation(fields: [campaign_send_id], references: [id])

  @@index([organization_id])
  @@index([organization_id, client_id])
  @@index([organization_id, status])
  @@index([organization_id, issue_date])
  @@map("invoices")
}

model Campaign {
  id              String         @id @default(cuid())
  organization_id String
  slug            String
  month_year      String
  label           String
  status          CampaignStatus @default(DRAFT)
  pdf_nf_key      String?
  pdf_boleto_key  String?
  kb_nf           Float?
  kb_boleto       Float?
  started_at      DateTime?
  completed_at    DateTime?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  organization Organization   @relation(fields: [organization_id], references: [id])
  sends        CampaignSend[]

  @@unique([organization_id, slug])
  @@index([organization_id])
  @@map("campaigns")
}

model CampaignSend {
  id           String     @id @default(cuid())
  campaign_id  String
  client_cnpj  String
  client_name  String
  emails       String[]
  status       SendStatus @default(PENDING)
  nf_pages     Int[]
  boleto_pages Int[]
  pixel_id             String?    @unique
  is_simulated         Boolean    @default(false)
  sent_at              DateTime?
  opened_at            DateTime?
  open_count           Int        @default(0)
  boleto_downloaded_at DateTime?
  nf_downloaded_at     DateTime?
  error_msg            String?
  created_at           DateTime   @default(now())

  campaign Campaign    @relation(fields: [campaign_id], references: [id])
  logs     EmailLog[]
  boleto   Boleto?
  invoice  Invoice?

  @@index([campaign_id])
  @@index([pixel_id])
  @@map("campaign_sends")
}

model EmailLog {
  id         String   @id @default(cuid())
  send_id    String
  type       String
  message    String
  created_at DateTime @default(now())

  send CampaignSend @relation(fields: [send_id], references: [id])

  @@index([send_id])
  @@map("email_logs")
}

model Ticket {
  id              String         @id @default(cuid())
  organization_id String
  number          Int
  client_id       String
  assigned_to     String?
  opened_by       String
  opened_by_type  String
  title           String
  category        String?
  status          TicketStatus   @default(OPEN)
  priority        TicketPriority @default(MEDIUM)
  sla_deadline    DateTime?
  resolved_at     DateTime?
  closed_at       DateTime?
  auto_close_at   DateTime?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  organization Organization     @relation(fields: [organization_id], references: [id])
  client       Client           @relation(fields: [client_id], references: [id])
  assignee     User?            @relation("AssignedTickets", fields: [assigned_to], references: [id])
  messages     TicketMessage[]
  attachments  TicketAttachment[]

  @@unique([organization_id, number])
  @@index([organization_id])
  @@index([organization_id, client_id])
  @@index([organization_id, status])
  @@index([organization_id, assigned_to])
  @@map("tickets")
}

model TicketMessage {
  id          String   @id @default(cuid())
  ticket_id   String
  author_id   String
  author_type String
  body        String   @db.Text
  is_internal Boolean  @default(false)
  is_auto     Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  ticket      Ticket             @relation(fields: [ticket_id], references: [id])
  attachments TicketAttachment[]

  @@index([ticket_id])
  @@map("ticket_messages")
}

model TicketAttachment {
  id         String   @id @default(cuid())
  ticket_id  String
  message_id String?
  file_key   String
  file_name  String
  mime_type  String
  size_kb    Float
  created_at DateTime @default(now())

  ticket  Ticket         @relation(fields: [ticket_id], references: [id])
  message TicketMessage? @relation(fields: [message_id], references: [id])

  @@index([ticket_id])
  @@map("ticket_attachments")
}

model Notification {
  id              String           @id @default(cuid())
  organization_id String
  user_id         String
  type            NotificationType
  title           String
  body            String
  link            String?
  is_read         Boolean          @default(false)
  read_at         DateTime?
  metadata        Json?
  created_at      DateTime         @default(now())

  organization Organization @relation(fields: [organization_id], references: [id])
  user         User         @relation(fields: [user_id], references: [id])

  @@index([organization_id, user_id])
  @@index([organization_id, user_id, is_read])
  @@map("notifications")
}

model ActivityLog {
  id              String   @id @default(cuid())
  organization_id String?
  user_id         String?
  action          String
  entity          String?
  entity_id       String?
  payload         Json?
  ip_address      String?
  user_agent      String?
  created_at      DateTime @default(now())

  organization Organization? @relation(fields: [organization_id], references: [id])
  user         User?         @relation(fields: [user_id], references: [id])

  @@index([organization_id])
  @@index([organization_id, entity, entity_id])
  @@index([created_at])
  @@map("activity_log")
}

model EmailTemplate {
  id              String   @id @default(cuid())
  organization_id String
  name            String
  subject         String   @default("Nota Fiscal - {mes_ano}")
  body            String   @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id])

  @@unique([organization_id, name])
  @@map("email_templates")
}

model WebhookEvent {
  id              String   @id @default(cuid())
  organization_id String
  event_type      String
  payload         Json
  status          String   @default("pending")
  attempts        Int      @default(0)
  last_attempt_at DateTime?
  delivered_at    DateTime?
  error_msg       String?
  created_at      DateTime @default(now())

  organization Organization @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([organization_id, status])
  @@map("webhook_events")
}

model Product {
  id              String      @id @default(cuid())
  organization_id String
  type            ProductType @default(SERVICE)
  name            String
  description     String?
  unit            String?     @default("un")
  price           Decimal     @db.Decimal(12, 2) @default(0)
  stock_quantity  Int?
  is_active       Boolean     @default(true)
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  organization   Organization   @relation(fields: [organization_id], references: [id])
  proposal_items ProposalItem[]

  @@index([organization_id])
  @@map("products")
}

model Proposal {
  id              String         @id @default(cuid())
  organization_id String
  client_id       String
  contract_id     String?
  number          Int
  title           String
  status          ProposalStatus @default(DRAFT)
  valid_until     DateTime?
  discount        Decimal        @db.Decimal(12, 2) @default(0)
  total           Decimal        @db.Decimal(12, 2) @default(0)
  total_monthly   Decimal        @db.Decimal(12, 2) @default(0)
  total_onetime   Decimal        @db.Decimal(12, 2) @default(0)
  payment_method  String?
  freight         Decimal        @db.Decimal(12, 2) @default(0)
  notes           String?        @db.Text
  sent_at         DateTime?
  viewed_at       DateTime?
  accepted_at     DateTime?
  rejected_at     DateTime?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  organization    Organization   @relation(fields: [organization_id], references: [id])
  client          Client         @relation(fields: [client_id], references: [id])
  contract        Contract?      @relation("ProposalToContract", fields: [contract_id], references: [id])
  items           ProposalItem[]
  origin_contracts Contract[]    @relation("ContractOriginProposal")
  labels          ProposalLabel[]

  @@unique([organization_id, number])
  @@index([organization_id])
  @@index([organization_id, client_id])
  @@map("proposals")
}

model ProposalItem {
  id          String           @id @default(cuid())
  proposal_id String
  product_id  String?
  description String
  unit        String?          @default("un")
  quantity    Decimal          @db.Decimal(10, 3) @default(1)
  unit_price  Decimal          @db.Decimal(12, 2)
  total       Decimal          @db.Decimal(12, 2)
  item_type   ProposalItemType @default(MONTHLY_SERVICE)
  sort_order  Int              @default(0)
  created_at  DateTime         @default(now())

  proposal Proposal @relation(fields: [proposal_id], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [product_id], references: [id])

  @@index([proposal_id])
  @@map("proposal_items")
}

model Contract {
  id              String         @id @default(cuid())
  organization_id String
  client_id       String
  proposal_id     String?
  title           String
  content         String?        @db.Text
  pdf_key         String?
  status          ContractStatus @default(DRAFT)
  sent_at         DateTime?
  viewed_at       DateTime?
  signed_at       DateTime?
  expires_at      DateTime?
  sign_token      String?        @unique
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  organization Organization  @relation(fields: [organization_id], references: [id])
  client       Client        @relation(fields: [client_id], references: [id])
  proposal     Proposal?     @relation("ContractOriginProposal", fields: [proposal_id], references: [id])
  proposals    Proposal[]    @relation("ProposalToContract")
  labels       ContractLabel[]

  @@index([organization_id])
  @@index([organization_id, client_id])
  @@map("contracts")
}

model KnowledgeArticle {
  id              String   @id @default(cuid())
  organization_id String
  title           String
  content         String   @db.Text
  category        String?
  visibility      String   @default("PUBLIC")  // PUBLIC | INTERNAL
  status          String   @default("DRAFT")   // DRAFT | PUBLISHED
  created_by      String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id])

  @@index([organization_id])
  @@index([organization_id, visibility, status])
  @@map("knowledge_articles")
}

model SalesLabel {
  id              String   @id @default(cuid())
  organization_id String
  name            String
  color           String   @default("#6366f1")
  description     String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization   @relation(fields: [organization_id], references: [id])
  proposals    ProposalLabel[]
  contracts    ContractLabel[]

  @@index([organization_id])
  @@map("sales_labels")
}

model ProposalLabel {
  proposal_id String
  label_id    String

  proposal Proposal   @relation(fields: [proposal_id], references: [id], onDelete: Cascade)
  label    SalesLabel @relation(fields: [label_id], references: [id], onDelete: Cascade)

  @@id([proposal_id, label_id])
  @@map("proposal_labels")
}

model ContractLabel {
  contract_id String
  label_id    String

  contract Contract   @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  label    SalesLabel @relation(fields: [label_id], references: [id], onDelete: Cascade)

  @@id([contract_id, label_id])
  @@map("contract_labels")
}

model PixCharge {
  id              String    @id @default(cuid())
  organization_id String
  client_id       String
  description     String
  amount          Decimal   @db.Decimal(12, 2)
  pix_key         String?
  qr_code         String?   @db.Text
  qr_code_image   String?
  status          PixStatus @default(PENDING)
  empresa_id      String?
  expires_at      DateTime?
  paid_at         DateTime?
  notes           String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  organization  Organization  @relation(fields: [organization_id], references: [id])
  client        Client        @relation(fields: [client_id], references: [id])
  empresa       Empresa?      @relation(fields: [empresa_id], references: [id])
  conta_receber ContaReceber?

  @@index([organization_id])
  @@index([organization_id, client_id])
  @@index([organization_id, status])
  @@map("pix_charges")
}
